{
  "rules": [
    {
      "allowed": {
        "origins": ["https://clips.zekurio.me"],
        "methods": ["GET", "PUT"],
        "headers": ["*"]
      },
      "exposeHeaders": [
        "Content-Range",
        "Content-Length",
        "ETag",
        "Accept-Ranges"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
