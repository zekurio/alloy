{
  "version": 1,
  "disable_existing_loggers": false,
  "root": {
    "level": "INFO",
    "handlers": ["default"]
  },
  "handlers": {
    "default": {
      "class": "alloy_ml.config.CustomRichHandler"
    }
  },
  "loggers": {
    "gunicorn.error": {
      "level": "INFO",
      "handlers": ["default"],
      "propagate": false
    },
    "gunicorn.access": {
      "level": "WARNING",
      "handlers": ["default"],
      "propagate": false
    }
  }
}
