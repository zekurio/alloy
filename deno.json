{
  "version": "0.0.6",
  "workspace": [
    "apps/*",
    "packages/*"
  ],
  "nodeModulesDir": "auto",
  "fmt": {
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": false,
    "singleQuote": false,
    "exclude": [
      "apps/web/src/routeTree.gen.ts",
      "machine-learning/.venv",
      "node_modules"
    ]
  },
  "lint": {
    "exclude": [
      "apps/web/src/routeTree.gen.ts",
      "machine-learning/.venv",
      "node_modules"
    ],
    "rules": {
      "exclude": [
        "no-slow-types",
        "no-sloppy-imports",
        "no-process-global",
        "no-window",
        "no-window-prefix",
        "require-await",
        "verbatim-module-syntax"
      ]
    }
  },
  "imports": {
    "@base-ui/react": "npm:@base-ui/react@1.4.1",
    "@fontsource-variable/dm-sans": "npm:@fontsource-variable/dm-sans@5.2.8",
    "@fontsource/ibm-plex-mono": "npm:@fontsource/ibm-plex-mono@5.2.7",
    "@hono/zod-validator": "npm:@hono/zod-validator@0.7.6",
    "@matmen/imagescript": "jsr:@matmen/imagescript@1.3.1",
    "@simplewebauthn/browser": "npm:@simplewebauthn/browser@13.3.0",
    "@simplewebauthn/server": "npm:@simplewebauthn/server@13.3.0",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@4.2.4",
    "@tanstack/react-form": "npm:@tanstack/react-form@1.29.1",
    "@tanstack/react-query": "npm:@tanstack/react-query@5.99.2",
    "@tanstack/react-router": "npm:@tanstack/react-router@1.168.23",
    "@tanstack/router-plugin": "npm:@tanstack/router-plugin@1.167.22",
    "@types/deno": "npm:@types/deno@2.5.0",
    "@types/node": "npm:@types/node@25.6.0",
    "@types/react": "npm:@types/react@19.2.14",
    "@types/react-dom": "npm:@types/react-dom@19.2.3",
    "@vitejs/plugin-react": "npm:@vitejs/plugin-react@5.2.0",
    "aws4fetch": "npm:aws4fetch@1.0.20",
    "class-variance-authority": "npm:class-variance-authority@0.7.1",
    "clsx": "npm:clsx@2.1.1",
    "drizzle-kit": "npm:drizzle-kit@0.31.10",
    "drizzle-orm": "npm:drizzle-orm@0.45.2",
    "embla-carousel-react": "npm:embla-carousel-react@8.6.0",
    "hls.js": "npm:hls.js@1.6.16",
    "hono": "npm:hono@4.12.14",
    "lucide-react": "npm:lucide-react@1.8.0",
    "openid-client": "npm:openid-client@6.8.2",
    "postgres": "npm:postgres@3.4.7",
    "react": "npm:react@19.2.5",
    "react-dom": "npm:react-dom@19.2.5",
    "sonner": "npm:sonner@2.0.7",
    "tailwind-merge": "npm:tailwind-merge@3.5.0",
    "tailwindcss": "npm:tailwindcss@4.2.4",
    "tw-animate-css": "npm:tw-animate-css@1.4.0",
    "vaul": "npm:vaul@1.1.2",
    "vite": "npm:vite@8.0.10",
    "zod": "npm:zod@4.3.6"
  },
  "tasks": {
    "build": "deno task --filter @workspace/server build && deno task --filter @workspace/web build",
    "start": "deno task start:prod",
    "start:prod": "WEB_DIST_DIR=${WEB_DIST_DIR:-../../apps/web/dist} deno task --cwd apps/server start:prod",
    "serve": "deno task start",
    "dev": "devenv up --strict-ports api web ml",
    "pg:stop": "sh -c 'devenv processes down || true; if [ -d .devenv/state/postgres ]; then pg_ctl -D .devenv/state/postgres stop -m fast || true; fi'",
    "pg:status": "pg_isready -d \"$DATABASE_URL\"",
    "db:generate": "deno task --cwd packages/db db:generate",
    "db:migrate": "deno task --cwd packages/db db:migrate",
    "db:push": "deno task --cwd packages/db db:push",
    "db:studio": "deno task --cwd packages/db db:studio",
    "fmt": "deno fmt && deno task --filter '*' fmt",
    "lint": "deno task --filter '*' lint",
    "lint:github": "deno task --filter '*' lint",
    "lint:ci": "deno task lint",
    "format": "deno task fmt",
    "typecheck": "deno task --filter '*' typecheck"
  },
  "allowScripts": {
    "deny": [
      "npm:esbuild@0.25.12"
    ]
  }
}
