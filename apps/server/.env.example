# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alloy

# Local server. In production this must be the externally reachable origin,
# not localhost or a loopback address.
PUBLIC_SERVER_URL=http://localhost:3000
PORT=3000

# Packaged web build override
# WEB_DIST_DIR=../web/dist
TRUSTED_ORIGINS=http://localhost:5173

# Runtime config
# Stores admin-tunable settings such as storage, OAuth, upload limits,
# integrations, and encoder profiles. Docker uses this persistent path.
# ALLOY_CONFIG_FILE=/var/lib/alloy/runtime-config.json

# Storage config override
# When any ALLOY_STORAGE_* variable is set, storage is managed by env and the
# admin UI cannot change it. Set ALLOY_STORAGE_DRIVER to choose fs or s3.
# ALLOY_STORAGE_DRIVER=fs
# ALLOY_STORAGE_FS_ROOT=./data/storage
# ALLOY_STORAGE_FS_PUBLIC_BASE_URL=http://localhost:3000
# ALLOY_STORAGE_FS_HMAC_SECRET=change-me-to-at-least-32-characters
# ALLOY_STORAGE_DRIVER=s3
# ALLOY_STORAGE_S3_BUCKET=alloy-clips
# ALLOY_STORAGE_S3_REGION=auto
# ALLOY_STORAGE_S3_ENDPOINT=https://s3.amazonaws.com
# ALLOY_STORAGE_S3_ACCESS_KEY_ID=
# ALLOY_STORAGE_S3_SECRET_ACCESS_KEY=
# ALLOY_STORAGE_S3_FORCE_PATH_STYLE=false
# ALLOY_STORAGE_S3_PRESIGN_EXPIRES_SEC=900

# Encoding
# Docker uses this persistent scratch path for encode working files.
# ENCODE_SCRATCH_DIR=/var/cache/alloy/encode
# Defaults to PATH lookup; override when ffmpeg/ffprobe live elsewhere.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
