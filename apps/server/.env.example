# Postgres connection string for Drizzle + Better Auth.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alloy

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-secret
BETTER_AUTH_URL=http://localhost:3000

# Port the Hono server listens on.
PORT=3000

# Comma-separated list of web origins allowed to call the API with credentials.
TRUSTED_ORIGINS=http://localhost:5173

# Optional — where to persist the JSON-backed runtime config (OAuth
# provider, openRegistrations, setupComplete). Defaults to
# ./data/runtime-config.json.
# RUNTIME_CONFIG_PATH=/var/lib/alloy/runtime-config.json

# ── Storage ──────────────────────────────────────────────────────────────
# Driver — `fs` (local disk) or `s3` (any S3-compatible bucket: AWS S3,
# Cloudflare R2, Tigris/Railway, MinIO, …).
STORAGE_DRIVER=fs
# Where the fs driver writes clip bytes. Created on demand. Stay off any
# directory another process touches; the reaper assumes exclusive ownership.
STORAGE_FS_ROOT=./data/storage
# Origin the browser POSTs uploads to (fs driver only). Set to the public
# API URL behind a proxy.
STORAGE_PUBLIC_BASE_URL=http://localhost:3000
# HMAC secret for fs upload tokens — generate with: openssl rand -base64 32
STORAGE_HMAC_SECRET=replace-me-with-a-32-char-secret

# S3 / S3-compatible — only read when STORAGE_DRIVER=s3.
# Bucket CORS must allow PUT (for direct browser uploads) and GET with
# the Range header (for playback) from your web origin. Example for R2:
#   [{ "AllowedMethods": ["PUT","GET"],
#      "AllowedOrigins": ["https://your-web-origin"],
#      "AllowedHeaders": ["content-type","range"],
#      "ExposeHeaders": ["content-length","content-range","accept-ranges"] }]
# S3_BUCKET=alloy-clips
# Region. R2 accepts `auto`; AWS wants the real region (e.g. `us-east-1`).
# S3_REGION=auto
# Custom endpoint — required for R2 (https://<account>.r2.cloudflarestorage.com),
# Railway (the URL Railway gives you), MinIO (http://minio:9000). Leave
# unset for real AWS S3.
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# Static credentials. Omit to fall back to the AWS SDK default credential
# chain (instance role, shared config file, workload identity, …).
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# MinIO needs path-style; R2/AWS/Tigris use virtual-hosted (the default).
# S3_FORCE_PATH_STYLE=false
# Presigned URL lifetime for playback/download 302s. Clients refresh via
# the share page, so this only needs to be long enough for a single
# playback session.
# S3_PRESIGN_EXPIRES_SEC=900

# ── Encoding ─────────────────────────────────────────────────────────────
# ffmpeg/ffprobe binary paths. The encoder *settings* (codec, hwaccel,
# CRF/quality, target height, audio bitrate) plus upload limits and queue
# concurrency are admin-tunable in Settings → Admin and persist in the
# runtime config JSON — they are not env vars.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# Optional — overrides the scratch dir the encoder stages source/variant
# files in. Defaults to `$TMPDIR/alloy-encode`. Point at a fast SSD or a
# larger mount when /tmp is small.
# ENCODE_SCRATCH_DIR=/var/cache/alloy/encode

# ── Cache ────────────────────────────────────────────────────────────────
# Backs the view-dedup window (see apps/server/src/cache). `memory` is a
# single-process in-house Map; a `redis` driver will slot in here later
# for horizontal scale-out.
CACHE_DRIVER=memory
