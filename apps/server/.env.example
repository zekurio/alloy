DATABASE_URL=postgres://postgres:postgres@localhost:5432/alloy

# generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-secret
PUBLIC_SERVER_URL=http://localhost:3000

PORT=3000

# comma-separated
TRUSTED_ORIGINS=http://localhost:5173

# persists OAuth config, openRegistrations, setupComplete; defaults to ./data/runtime-config.json
# RUNTIME_CONFIG_PATH=/var/lib/alloy/runtime-config.json

# ── Storage ──────────────────────────────────────────────────────────────
# `fs` or `s3`
STORAGE_DRIVER=fs
STORAGE_FS_ROOT=./data/storage
# public server URL used for upload targets (fs driver only)
STORAGE_PUBLIC_BASE_URL=http://localhost:3000
# generate with: openssl rand -base64 32
STORAGE_HMAC_SECRET=replace-me-with-a-32-char-secret

# S3 / S3-compatible — only used when STORAGE_DRIVER=s3
# S3_BUCKET=alloy-clips
# S3_REGION=auto
# required for R2/Railway/MinIO; omit for AWS S3
# S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=false
# S3_PRESIGN_EXPIRES_SEC=900

# ── Encoding ─────────────────────────────────────────────────────────────
# encoder settings are admin-tunable in Settings → Admin, not env vars
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
# defaults to $TMPDIR/alloy-encode
# ENCODE_SCRATCH_DIR=/var/cache/alloy/encode

# ── Cache ────────────────────────────────────────────────────────────────
# `memory` (single-process) — redis support planned
CACHE_DRIVER=memory
