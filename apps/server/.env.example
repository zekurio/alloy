# Postgres connection string for Drizzle + Better Auth.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/alloy

# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-char-secret
BETTER_AUTH_URL=http://localhost:3000

# Port the Hono server listens on.
PORT=3000

# Comma-separated list of web origins allowed to call the API with credentials.
TRUSTED_ORIGINS=http://localhost:5173

# Optional — where to persist the JSON-backed runtime config (OAuth
# provider, openRegistrations, setupComplete). Defaults to
# ./data/runtime-config.json.
# RUNTIME_CONFIG_PATH=/var/lib/alloy/runtime-config.json

# ── Storage ──────────────────────────────────────────────────────────────
# Driver — only `fs` exists today; `s3` slots in here later.
STORAGE_DRIVER=fs
# Where the fs driver writes clip bytes. Created on demand. Stay off any
# directory another process touches; the reaper assumes exclusive ownership.
STORAGE_FS_ROOT=./data/storage
# Origin the browser POSTs uploads to. For local dev this is the same Hono
# server. Behind a proxy, set this to the public API URL.
STORAGE_PUBLIC_BASE_URL=http://localhost:3000
# HMAC secret for upload tokens — generate with: openssl rand -base64 32
STORAGE_HMAC_SECRET=replace-me-with-a-32-char-secret

# ── Encoding ─────────────────────────────────────────────────────────────
# ffmpeg/ffprobe binary paths. The encoder *settings* (codec, hwaccel,
# CRF/quality, target height, audio bitrate) plus upload limits and queue
# concurrency are admin-tunable in Settings → Admin and persist in the
# runtime config JSON — they are not env vars.
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ── Cache ────────────────────────────────────────────────────────────────
# Backs the view-dedup window (see apps/server/src/cache). `memory` is a
# single-process in-house Map; a `redis` driver will slot in here later
# for horizontal scale-out.
CACHE_DRIVER=memory
