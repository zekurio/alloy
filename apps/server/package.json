{
  "name": "@workspace/server",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "PORT=3000 BETTER_AUTH_URL=http://localhost:3000 TRUSTED_ORIGINS=http://localhost:5173 tsx watch src/index.ts",
    "start": "PORT=3000 BETTER_AUTH_URL=http://localhost:3000 TRUSTED_ORIGINS=http://localhost:5173 tsx src/index.ts",
    "build": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "typecheck": "tsgo --noEmit",
    "db:generate": "pnpm --dir ../../packages/db db:generate",
    "db:migrate": "pnpm --dir ../../packages/db db:migrate",
    "db:push": "pnpm --dir ../../packages/db db:push",
    "db:studio": "pnpm --dir ../../packages/db db:studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.18.2",
    "@hono/zod-validator": "^0.7.4",
    "@workspace/db": "workspace:*",
    "better-auth": "^1.3.8",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.9.10",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@typescript/native-preview": "*",
    "oxfmt": "*",
    "oxlint": "*",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  },
  "exports": {
    "./app": "./src/app.ts",
    "./auth": "./src/auth.ts"
  }
}
