{
  "name": "@workspace/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "PORT=3000 PUBLIC_SERVER_URL=http://localhost:3000 TRUSTED_ORIGINS=http://localhost:5173 bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "typecheck": "tsgo --noEmit",
    "db:generate": "bun --cwd ../../packages/db db:generate",
    "db:migrate": "bun --cwd ../../packages/db db:migrate",
    "db:push": "bun --cwd ../../packages/db db:push",
    "db:studio": "bun --cwd ../../packages/db db:studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@simplewebauthn/server": "^13.3.0",
    "@workspace/contracts": "workspace:*",
    "@workspace/db": "workspace:*",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "isomorphic-dompurify": "^3.9.0",
    "jose": "^6.2.2",
    "nanoid": "^5.1.9",
    "openid-client": "^6.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "@types/node": "^25.6.0",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  }
}
