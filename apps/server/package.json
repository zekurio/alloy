{
  "name": "@workspace/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
    "dev": "PORT=3000 BETTER_AUTH_URL=http://localhost:3000 TRUSTED_ORIGINS=http://localhost:5173 tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsgo --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "typecheck": "tsgo --noEmit",
    "db:generate": "pnpm --dir ../../packages/db db:generate",
    "db:migrate": "pnpm --dir ../../packages/db db:migrate",
    "db:push": "pnpm --dir ../../packages/db db:push",
    "db:studio": "pnpm --dir ../../packages/db db:studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/lib-storage": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "@better-auth/passkey": "^1.6.6",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "@workspace/contracts": "workspace:*",
    "@workspace/db": "workspace:*",
    "better-auth": "^1.6.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "isomorphic-dompurify": "^3.9.0",
    "nanoid": "^5.1.9",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  }
}
