{
  "name": "web",
  "exports": {
    ".": "./src/main.tsx"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable", "DOM.AsyncIterable", "deno.ns"],
    "types": ["vite/client"],
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "drizzle-orm": [
        "../../node_modules/.deno/drizzle-orm@0.45.2/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../../node_modules/.deno/drizzle-orm@0.45.2/node_modules/drizzle-orm/*"
      ],
      "postgres": [
        "../../node_modules/.deno/postgres@3.4.7/node_modules/postgres"
      ],
      "@workspace/ui/globals.css": ["../../packages/ui/src/styles/globals.css"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@workspace/api": ["../../packages/api/src/index.ts"],
      "@workspace/api/*": ["../../packages/api/src/*"],
      "@workspace/contracts": ["../../packages/contracts/src/index.ts"],
      "@workspace/contracts/*": ["../../packages/contracts/src/*"],
      "@workspace/db": ["../../packages/db/src/index.ts"],
      "@workspace/db/*": ["../../packages/db/src/*"]
    }
  },
  "tasks": {
    "dev": "deno run -A npm:vite@^8.0.10 dev --port 5173 --strictPort",
    "build": "deno run -A npm:vite@^8.0.10 build",
    "preview": "deno run -A npm:vite@^8.0.10 preview --port 5173 --strictPort",
    "lint": "deno run -A npm:oxlint@^1.61.0 .",
    "fmt": "deno run -A npm:oxfmt@^0.46.0 --write .",
    "format": "deno task fmt",
    "typecheck": "deno check ."
  }
}
