# ─────────────────────────────────────────────────────────────
# Web dev env
# Copy to .env only for split local development. Production serves the built
# web app from the Alloy server, so browser API calls default to same-origin.
# ─────────────────────────────────────────────────────────────

# Public origin of the local Alloy server. Browser code calls this URL directly
# while Vite runs on http://localhost:5173.
# Do not include a trailing `/api`.
VITE_SERVER_URL=http://localhost:3000
