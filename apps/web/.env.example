# ─────────────────────────────────────────────────────────────
# Web service env
# Copy to .env (dev) or paste into Railway variables (prod).
# ─────────────────────────────────────────────────────────────

# Origin the Nitro `/api/$` and `/events/$` proxies forward to, and
# the origin SSR loaders use for direct API fetches. In a single
# container this is localhost; on Railway it's the server service's
# private-network hostname (IPv6-only, Node 24 handles it).
INTERNAL_API_URL=http://localhost:3000

# Public origin of the web app — the URL users type into their
# browser. Used during SSR to build absolute URLs (thumbnails,
# stream, download, game hero) that land in the HTML response.
# Must be reachable from the browser; never an internal hostname.
PUBLIC_APP_URL=http://localhost:3000
