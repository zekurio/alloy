{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript"],
  "env": {
    "browser": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist/**",
    ".output/**",
    ".nitro/**",
    ".tanstack/**",
    ".vinxi/**",
    ".turbo/**",
    "coverage/**"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "typescript/no-explicit-any": "warn"
  }
}
