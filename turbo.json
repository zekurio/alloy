{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["tsconfig.base.json"],
  "globalEnv": [
    "ALLOY_DATA_DIR",
    "DATABASE_URL",
    "NODE_ENV",
    "PORT",
    "PUBLIC_SERVER_URL",
    "TRUSTED_ORIGINS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "env": [
        "ALLOY_TEST_DATABASE_URL",
        "ALLOY_UPLOAD_HMAC_SECRET",
        "ALLOY_VIEWER_COOKIE_SECRET"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
