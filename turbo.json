{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "ALLOY_DATA_DIR",
    "DATABASE_URL",
    "FFMPEG_BIN",
    "FFPROBE_BIN",
    "NODE_ENV",
    "PORT",
    "PUBLIC_SERVER_URL",
    "TRUSTED_ORIGINS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
