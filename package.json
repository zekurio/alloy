{
  "name": "alloy",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "package:web": "rm -rf build/www && mkdir -p build && cp -R apps/web/dist build/www",
    "start": "bun --filter @workspace/server start",
    "serve": "bun run start",
    "preview": "bun run build && bun run package:web && bun run start",
    "dev": "turbo dev",
    "db:generate": "bun --filter @workspace/db db:generate",
    "db:migrate": "bun --filter @workspace/db db:migrate",
    "db:push": "bun --filter @workspace/db db:push",
    "db:studio": "bun --filter @workspace/db db:studio",
    "migrate:deploy": "bun --filter @workspace/db migrate:deploy",
    "fmt": "bun run format",
    "lint": "turbo lint",
    "lint:github": "turbo lint -- --deny-warnings --format=github",
    "lint:ci": "turbo lint -- --deny-warnings",
    "format": "turbo format",
    "typecheck": "turbo typecheck"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "turbo": "^2.9.6",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.0"
  },
  "overrides": {
    "undici": "^7.24.0",
    "srvx": "^0.11.15",
    "h3": ">=2.0.1-rc.18",
    "h3-v2": "npm:h3@>=2.0.1-rc.18",
    "brace-expansion": "^5.0.5",
    "esbuild": "^0.25.0"
  }
}
