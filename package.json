{
  "name": "alloy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "node scripts/dev.mjs api web ml",
    "dev:server": "node scripts/dev.mjs api",
    "dev:web": "node scripts/dev.mjs web",
    "dev:ml": "node scripts/dev.mjs ml",
    "dev:desktop": "node scripts/dev.mjs api web desktop",
    "dev:all": "node scripts/dev.mjs api web ml desktop",
    "desktop:build": "pnpm --filter alloy-desktop build",
    "desktop:dist:linux": "pnpm --filter alloy-desktop dist:linux",
    "desktop:dist:win": "pnpm --filter alloy-desktop dist:win",
    "desktop:dist:win:installer": "pnpm --filter alloy-desktop dist:win:installer",
    "desktop:dist:all": "pnpm --filter alloy-desktop dist:all",
    "start": "pnpm --filter alloy-server start",
    "start:prod": "pnpm --filter alloy-server start",
    "db:generate": "pnpm --filter alloy-db db:generate",
    "db:migrate": "pnpm --filter alloy-db db:migrate",
    "db:push": "pnpm --filter alloy-db db:push",
    "db:studio": "pnpm --filter alloy-db db:studio",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:github": "pnpm lint",
    "lint:ci": "pnpm lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/pg": "8.20.0",
    "oxfmt": "0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "tsx": "4.22.4",
    "turbo": "2.9.16",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.4.0"
}
