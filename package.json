{
  "name": "alloy",
  "version": "1.4.2",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm db:push && turbo run dev --filter=@alloy/server --filter=@alloy/web",
    "dev:server": "pnpm db:push && turbo run dev --filter=@alloy/server",
    "dev:web": "turbo run dev --filter=@alloy/web",
    "dev:all": "pnpm db:push && turbo run dev --filter=@alloy/server --filter=@alloy/web --filter=@alloy/desktop",
    "recorder:build": "pnpm --filter @alloy/recorder build",
    "recorder:build:release": "pnpm --filter @alloy/recorder build:release",
    "recorder:obs:install": "pnpm --filter @alloy/recorder obs:install",
    "desktop:obs:install": "pnpm --filter @alloy/recorder obs:install",
    "desktop:build": "pnpm --filter @alloy/desktop build",
    "desktop:dist:win": "pnpm --filter @alloy/desktop dist:win",
    "desktop:dist:win:installer": "pnpm --filter @alloy/desktop dist:win:installer",
    "start": "pnpm --filter @alloy/server start",
    "start:prod": "pnpm --filter @alloy/server start",
    "db:generate": "pnpm --filter @alloy/db db:generate",
    "db:migrate": "pnpm --filter @alloy/db db:migrate",
    "db:push": "pnpm --filter @alloy/db db:push",
    "db:studio": "pnpm --filter @alloy/db db:studio",
    "audit": "pnpm audit",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:github": "pnpm lint",
    "lint:ci": "pnpm lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm fmt:check && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "tsx": "4.23.1",
    "turbo": "2.10.5",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.13.0"
}
