# Local development environment for setups without devenv (devenv shells
# export all of this automatically and always win over this file).
# Copy to `.env`; variables already set in the shell are never overridden.

# Postgres from docker-compose.dev.yml. For a system-wide instance, point at
# it instead, e.g. postgres://user:pass@127.0.0.1:5432/alloy
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/alloy

# Server defaults (see packages/server/src/env.ts):
PORT=2552
PUBLIC_SERVER_URL=http://localhost:2552

# Required internal signing secrets. Use unique random 32+ character values.
ALLOY_VIEWER_COOKIE_SECRET=dev-viewer-cookie-secret-32-bytes-min
ALLOY_UPLOAD_HMAC_SECRET=dev-upload-hmac-secret-32-bytes-min

# Allow the Vite dev server origin to call the API.
TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth policy and upload limits.
ALLOY_OPEN_REGISTRATIONS=false
ALLOY_PASSKEY_ENABLED=true
ALLOY_REQUIRE_AUTH_TO_BROWSE=true
# ALLOY_DEFAULT_STORAGE_QUOTA_BYTES=
ALLOY_UPLOAD_TTL_SEC=900

# Filesystem storage.
ALLOY_STORAGE_DRIVER=fs
ALLOY_STORAGE_FS_CLIPS_PATH=../../data/storage/clips
ALLOY_STORAGE_FS_USERS_PATH=../../data/storage/users

# S3-compatible storage.
# ALLOY_STORAGE_DRIVER=s3
# ALLOY_STORAGE_S3_BUCKET=alloy
# ALLOY_STORAGE_S3_REGION=auto
# ALLOY_STORAGE_S3_ENDPOINT=https://s3.example.com
# ALLOY_STORAGE_S3_FORCE_PATH_STYLE=false
# ALLOY_STORAGE_S3_ACCESS_KEY_ID_FILE=/run/secrets/alloy-s3-access-key-id
# ALLOY_STORAGE_S3_SECRET_ACCESS_KEY_FILE=/run/secrets/alloy-s3-secret-access-key

# Optional integrations.
# ALLOY_STEAMGRIDDB_API_KEY_FILE=/run/secrets/alloy-steamgriddb-api-key

# Optional Paperless/allauth-style OIDC provider config. Prefer the _FILE
# variant because this JSON contains client secrets.
# ALLOY_SOCIALACCOUNT_PROVIDERS_FILE=/run/secrets/alloy-socialaccount-providers.json
# ALLOY_SOCIALACCOUNT_PROVIDERS={"openid_connect":{"SCOPE":["openid","identify","email"],"OAUTH_PKCE_ENABLED":true,"APPS":[{"provider_id":"discord","name":"Discord","client_id":"alloy","secret":"replace-me","settings":{"server_url":"https://discord.com","username_claim":"username","button_color":"#5865F2","button_text_color":"#ffffff","icon_url":"https://cdn.simpleicons.org/discord/white"}}]}}

# Standalone web dev (`pnpm dev:web`) proxies API calls to this server.
# Unset, it defaults to http://localhost:2552 (see packages/web/vite.config.ts).
# VITE_SERVER_URL=http://localhost:2552
