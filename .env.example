# Local development environment for setups without devenv (devenv shells
# export all of this automatically and always win over this file).
# Copy to `.env`; variables already set in the shell are never overridden.

# Postgres from docker-compose.dev.yml. For a system-wide instance, point at
# it instead, e.g. postgres://user:pass@127.0.0.1:5432/alloy
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/alloy

# Allow the Vite dev server origin to call the API.
TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Repo-root bootstrap data dir for config.json and secrets.json, resolved
# relative to packages/server where the server process runs. Unset, it defaults
# to packages/server/data. Storage roots are configured in Alloy setup/admin UI.
ALLOY_DATA_DIR=../../data

# Server defaults (see packages/server/src/env.ts):
# PORT=2552
# PUBLIC_SERVER_URL=http://localhost:2552

# Standalone web dev (`pnpm dev:web`) proxies API calls to this server.
# Unset, it defaults to http://localhost:2552 (see packages/web/vite.config.ts).
# VITE_SERVER_URL=http://localhost:2552
