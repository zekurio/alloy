{
  "name": "@alloy/server",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*_test.ts\"",
    "db:generate": "pnpm --filter @alloy/db db:generate",
    "db:migrate": "pnpm --filter @alloy/db db:migrate",
    "db:push": "pnpm --filter @alloy/db db:push",
    "db:studio": "pnpm --filter @alloy/db db:studio"
  },
  "dependencies": {
    "@alloy/contracts": "workspace:*",
    "@alloy/db": "workspace:*",
    "@alloy/env": "workspace:*",
    "@alloy/logging": "workspace:*",
    "@hono/node-server": "2.0.4",
    "@hono/zod-validator": "0.7.6",
    "@simplewebauthn/server": "13.3.0",
    "blurhash": "^2.0.5",
    "croner": "10.0.1",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.23",
    "mediabunny": "^1.46.0",
    "openid-client": "6.8.2",
    "pg": "8.21.0",
    "sharp": "^0.34.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "tsx": "latest",
    "vite": "8.0.10"
  }
}
