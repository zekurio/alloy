{
  "name": "@alloy/server",
  "private": true,
  "type": "module",
  "exports": {
    "./app": "./src/app.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "NODE_ENV=production node dist/index.js",
    "test": "tsx --test 'src/**/*.test.ts'",
    "test:config": "tsx --test src/config/*.test.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "pnpm --filter @alloy/db db:generate",
    "db:migrate": "pnpm --filter @alloy/db db:migrate",
    "db:push": "pnpm --filter @alloy/db db:push",
    "db:studio": "pnpm --filter @alloy/db db:studio"
  },
  "dependencies": {
    "@alloy/contracts": "workspace:*",
    "@alloy/db": "workspace:*",
    "@alloy/env": "workspace:*",
    "@alloy/logging": "workspace:*",
    "@hono/node-server": "2.0.8",
    "@hono/zod-validator": "0.8.0",
    "@simplewebauthn/server": "13.3.2",
    "blurhash": "2.0.5",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.29",
    "openid-client": "6.8.4",
    "pg": "8.22.0",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsx": "4.23.0",
    "vite": "8.1.4"
  }
}
