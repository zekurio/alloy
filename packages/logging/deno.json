{
  "name": "@workspace/logging",
  "exports": {
    ".": "./src/index.ts"
  },
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "deno.ns"],
    "strict": true
  },
  "tasks": {
    "lint": "deno run -A npm:oxlint@^1.61.0 src",
    "fmt": "deno run -A npm:oxfmt@^0.46.0 --write src deno.json tsconfig.json",
    "format": "deno task fmt",
    "typecheck": "deno check src"
  }
}
