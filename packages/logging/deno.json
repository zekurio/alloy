{
  "name": "@workspace/logging",
  "exports": {
    ".": "./src/index.ts"
  },
  "compilerOptions": {
    "lib": ["ES2023", "DOM", "deno.ns"],
    "strict": true
  },
  "tasks": {
    "lint": "deno lint src",
    "fmt": "deno fmt src deno.json tsconfig.json",
    "fmt:check": "deno fmt --check src deno.json tsconfig.json",
    "format": "deno task fmt",
    "typecheck": "deno check src"
  }
}
