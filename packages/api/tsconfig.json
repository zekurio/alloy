{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "paths": {
      "@workspace/contracts": ["../contracts/src/index.ts"],
      "@workspace/contracts/*": ["../contracts/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
