    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*_test.ts\""
  },
  "dependencies": {
    "@workspace/contracts": "workspace:*",
    "@workspace/logging": "workspace:*",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0"
  }
