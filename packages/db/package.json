{
  "name": "alloy-db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./auth-schema": "./src/auth-schema.ts",
    "./contracts": "./src/contracts.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node ../../scripts/with-dev-env.mjs node ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "node ../../scripts/with-dev-env.mjs node ./node_modules/drizzle-kit/bin.cjs push",
    "db:studio": "node ../../scripts/with-dev-env.mjs node ./node_modules/drizzle-kit/bin.cjs studio",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*_test.ts\""
  },
  "dependencies": {
    "alloy-contracts": "workspace:*",
    "alloy-logging": "workspace:*",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0"
  }
}
