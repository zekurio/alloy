{
  "name": "alloy-db",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./auth-schema": "./src/schema/auth.ts",
    "./contracts": "./src/contracts.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "db:generate": "node ../../scripts/db.mjs generate",
    "db:migrate": "node ../../scripts/db.mjs migrate",
    "db:push": "node ../../scripts/db.mjs push",
    "db:studio": "node ../../scripts/db.mjs studio",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*_test.ts\""
  },
  "dependencies": {
    "alloy-contracts": "workspace:*",
    "alloy-env": "workspace:*",
    "alloy-logging": "workspace:*",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "pg": "8.21.0",
    "zod": "4.3.6"
  }
}
