{
  "name": "@workspace/db",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./auth-schema": "./src/auth-schema.ts",
    "./contracts": "./src/contracts.ts"
  },
  "compilerOptions": {
    "module": "ESNext",
    "lib": ["ES2023", "DOM", "deno.ns"],
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "drizzle-orm": [
        "../../node_modules/.deno/drizzle-orm@0.45.2/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../../node_modules/.deno/drizzle-orm@0.45.2/node_modules/drizzle-orm/*"
      ],
      "@workspace/contracts": ["../contracts/src/index.ts"],
      "@workspace/contracts/*": ["../contracts/src/*"]
    }
  },
  "tasks": {
    "db:generate": "deno run -A npm:drizzle-kit@0.31.10 generate",
    "db:migrate": "deno run -A npm:drizzle-kit@0.31.10 migrate",
    "db:push": "deno run -A npm:drizzle-kit@0.31.10 push",
    "db:studio": "deno run -A npm:drizzle-kit@0.31.10 studio",
    "lint": "deno lint src drizzle.config.ts",
    "fmt": "deno fmt src drizzle.config.ts deno.json tsconfig.json",
    "fmt:check": "deno fmt --check src drizzle.config.ts deno.json tsconfig.json",
    "format": "deno task fmt",
    "typecheck": "deno check src drizzle.config.ts"
  }
}
