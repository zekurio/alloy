{
  "include": ["src/**/*.ts", "drizzle.config.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2023", "DOM"],
    "types": ["deno"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "drizzle-orm": [
        "../../node_modules/.deno/drizzle-orm@0.45.2/node_modules/drizzle-orm"
      ],
      "drizzle-orm/*": [
        "../../node_modules/.deno/drizzle-orm@0.45.2/node_modules/drizzle-orm/*"
      ],
      "@workspace/contracts": ["../contracts/src/index.ts"],
      "@workspace/contracts/*": ["../contracts/src/*"]
    }
  }
}
