{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.ts", "drizzle.config.ts"],
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"],
      "@alloy/contracts": ["../contracts/src/index.ts"],
      "@alloy/contracts/*": ["../contracts/src/*"]
    }
  }
}
