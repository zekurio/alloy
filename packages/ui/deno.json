{
  "name": "@workspace/ui",
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "tasks": {
    "lint": "deno run -A npm:oxlint@^1.61.0 src",
    "fmt": "deno run -A npm:oxfmt@^0.46.0 --write src deno.json tsconfig.json tsconfig.lint.json components.json",
    "format": "deno task fmt",
    "typecheck": "deno check src"
  }
}
